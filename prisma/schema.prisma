generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum GptAccountStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum CdkStatus {
  UNUSED
  ACTIVE
  EXHAUSTED
  EXPIRED
  REVOKED
}

enum EmailCodeSourceType {
  MONTHLY
  CDK
  ADMIN_TEST
}

enum EmailCodeRequestStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

enum CdkRedemptionStatus {
  SUCCESS
  FAILED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  wechatName         String?
  passwordHash       String
  role               UserRole            @default(USER)
  name               String?
  status             UserStatus          @default(ACTIVE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastLoginAt        DateTime?
  memberships        MonthlyMembership[]
  createdCdks        Cdk[]               @relation("CreatedCdks")
  redeemedCdks       Cdk[]               @relation("RedeemedCdks")
  emailCodeRequests  EmailCodeRequest[]
  auditLogs          AuditLog[]
}

model GptAccount {
  id                 String              @id @default(cuid())
  label              String
  loginEmail         String              @unique
  encryptedPassword  String
  status             GptAccountStatus    @default(ACTIVE)
  capacity           Int                 @default(3)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        MonthlyMembership[]
  cdks               Cdk[]
  emailCodeRequests  EmailCodeRequest[]
}

model MonthlyMembership {
  id                 String              @id @default(cuid())
  userId             String
  gptAccountId       String
  startsAt           DateTime
  endsAt             DateTime
  status             MembershipStatus    @default(ACTIVE)
  requestLimitPerDay Int                 @default(3)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id])
  gptAccount         GptAccount          @relation(fields: [gptAccountId], references: [id])

  @@index([userId])
  @@index([gptAccountId])
  @@index([status, startsAt, endsAt])
}

model Cdk {
  id                    String              @id @default(cuid())
  codeHash              String              @unique
  code                  String?
  displayCodeLast4      String
  durationDays          Int
  maxUses               Int
  remainingUses         Int
  status                CdkStatus           @default(UNUSED)
  gptAccountId          String
  createdByAdminId      String
  activatedAt           DateTime?
  validUntil            DateTime?
  redeemedByUserId      String?
  redeemedByFingerprint String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  gptAccount            GptAccount          @relation(fields: [gptAccountId], references: [id])
  createdByAdmin        User                @relation("CreatedCdks", fields: [createdByAdminId], references: [id])
  redeemedByUser        User?               @relation("RedeemedCdks", fields: [redeemedByUserId], references: [id])
  redemptions           CdkRedemption[]
  emailCodeRequests     EmailCodeRequest[]

  @@index([status])
  @@index([gptAccountId])
}

model CdkRedemption {
  id                 String              @id @default(cuid())
  cdkId              String
  userId             String?
  ipHash             String?
  userAgent          String?
  status             CdkRedemptionStatus
  failureReason      String?
  emailCodeRequestId String?
  createdAt          DateTime            @default(now())
  cdk                Cdk                 @relation(fields: [cdkId], references: [id])

  @@index([cdkId])
  @@index([createdAt])
}

model EmailCodeRequest {
  id                     String                 @id @default(cuid())
  sourceType             EmailCodeSourceType
  userId                 String?
  cdkId                  String?
  gptAccountId           String
  targetEmail            String
  status                 EmailCodeRequestStatus @default(PENDING)
  verificationCodeMasked String?
  providerMessageId      String?
  errorMessage           String?
  createdAt              DateTime               @default(now())
  completedAt            DateTime?
  user                   User?                  @relation(fields: [userId], references: [id])
  cdk                    Cdk?                   @relation(fields: [cdkId], references: [id])
  gptAccount             GptAccount             @relation(fields: [gptAccountId], references: [id])

  @@index([sourceType])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadataJson String?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String   @unique
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
